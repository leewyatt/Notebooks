<!--
  Loaded only when org.jetbrains.kotlin is present. Currently empty of
  functional extensions — the file exists so the plugin's optional
  dependency on Kotlin can be wired without forcing the whole plugin
  to require Kotlin.

  The supportsKotlinPluginMode declaration below is required by
  IntelliJ IDEA 2024.2.1+ when any plugin depends on org.jetbrains.kotlin.
  We support both K1 (classic) and K2 (new compiler) modes because this
  file contributes nothing Kotlin-compiler-specific.
-->
<idea-plugin>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
    </extensions>
</idea-plugin>
